# Path to the whisper.cpp main executable (e.g. main.exe on Windows, main on Linux)
WHISPER_CPP_PATH=C:/whisper.cpp/main.exe

# Path to the whisper GGML model (e.g. ggml-base.bin or ggml-tiny.bin)
WHISPER_MODEL_PATH=C:/whisper.cpp/models/ggml-base.bin

# Path to ffmpeg executable (optional, if ffmpeg is in your system PATH, you can leave it as 'ffmpeg')
FFMPEG_PATH=ffmpeg

# Whisper language code (e.g. 'id' for Indonesian, 'en' for English, 'auto' for auto-detect)
WHISPER_LANGUAGE=id

# Server host and port
HOST=127.0.0.1
PORT=8000
